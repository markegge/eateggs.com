<?xml version="1.0"?>
<ruleset name="eateggs">
	<description>Coding standards for the eateggs WordPress theme.</description>

	<!-- What to scan. -->
	<file>wp-content/themes/eateggs</file>

	<!-- Skip vendored / binary assets. -->
	<exclude-pattern>*/assets/fonts/*</exclude-pattern>
	<exclude-pattern>*/node_modules/*</exclude-pattern>
	<exclude-pattern>*/vendor/*</exclude-pattern>

	<!-- Only check PHP. -->
	<arg name="extensions" value="php"/>
	<arg name="colors"/>
	<arg value="sp"/>

	<!-- WordPress standards (requires wp-coding-standards/wpcs). -->
	<rule ref="WordPress-Core"/>
	<rule ref="WordPress-Docs"/>
	<rule ref="WordPress-Extra"/>

	<!-- Theme text domain check. -->
	<rule ref="WordPress.WP.I18n">
		<properties>
			<property name="text_domain" type="array">
				<element value="eateggs"/>
			</property>
		</properties>
	</rule>

	<config name="minimum_supported_wp_version" value="6.0"/>
</ruleset>
